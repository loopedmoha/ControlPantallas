ď»ż<Page
    x:Class="ControlPantallas.Pages.PageFondo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:ControlPantallas.Converters"
    xmlns:vm="using:ControlPantallas.ViewModels">

    <Page.DataContext>
        <vm:FondoViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NotificaciĂłn -->
        <InfoBar
            Grid.Row="0"
            IsOpen="{Binding MostrarNotificacion}"
            Message="{Binding Mensaje}"
            Severity="Informational"
            IsClosable="True"/>

        <!-- Layout principal -->
        <Grid
            Grid.Row="1"
            ColumnSpacing="14">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Panel principal -->
            <StackPanel
                Grid.Column="0"
                Spacing="10">

                <Button
                    Content="Seleccionar carpeta"
                    Command="{Binding SeleccionarCarpetaCommand}"
                    HorizontalAlignment="Left"/>

                <!-- GridView -->
                <GridView
                    ItemsSource="{Binding Fondos}"
                    SelectedItem="{Binding FondoSeleccionado, Mode=TwoWay}"
                    SelectionMode="Single"
                    IsItemClickEnabled="True"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollMode="Enabled">

                    <GridView.ItemTemplate>

                        <DataTemplate>

                            <StackPanel Width="200">

                                <Image
                                    Source="{Binding Ruta}"
                                    Height="130"
                                    Stretch="UniformToFill"/>

                                <TextBlock
                                    Text="{Binding Ruta}"
                                    FontSize="12"
                                    TextTrimming="CharacterEllipsis"/>

                                <TextBlock
                                    Text="{Binding Tipo}"
                                    FontSize="12"/>

                                <TextBlock
                                    Text="{Binding Pantalla}"
                                    FontSize="12"/>

                                <TextBlock
                                    Text="{Binding Transicion}"
                                    FontSize="12"/>

                            </StackPanel>

                        </DataTemplate>

                    </GridView.ItemTemplate>

                </GridView>

                <Button
    Content="Ańadir a Escaleta"
    Click="AnadirEscaleta_Click"/>
            </StackPanel>

            <!-- Panel derecho -->
            <StackPanel
                Grid.Column="1"
                Spacing="10">

                <Button
                    Content="Entra Fondo"
                    Command="{Binding EntraFondoCommand}"
                    Height="58"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Background="#198754"
                    Foreground="White"
                    BorderBrush="#198754"/>

                <Button
                    Content="Sale Fondo"
                    Command="{Binding SaleFondoCommand}"
                    Height="58"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Background="#DC3545"
                    Foreground="White"
                    BorderBrush="#DC3545"/>

                <Button
                    Content="AĂ±adir a Escaleta"
                    Command="{Binding AnadirAEscaletaCommand}"
                    Visibility="{Binding HayFondoSeleccionado, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <StackPanel
                    Spacing="8"
                    Visibility="{Binding HayFondoSeleccionado, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock
                        Text="Opciones del fondo seleccionado"
                        TextWrapping="WrapWholeWords"/>

                    <ComboBox
                        Header="Pantalla"
                        ItemsSource="{Binding TiposPantalla}"
                        SelectedItem="{Binding PantallaSeleccionada, Mode=TwoWay}"/>

                    <ComboBox
                        Header="TransiciĂłn"
                        ItemsSource="{Binding TiposTransicion}"
                        SelectedItem="{Binding TransicionSeleccionada, Mode=TwoWay}"/>

                </StackPanel>

            </StackPanel>

        </Grid>

    </Grid>

</Page>
